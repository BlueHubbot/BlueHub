# =============================================================================
# BlueHub Development Environment Variables
# =============================================================================
# Copy this file to .env and adjust values as needed.
# Never commit .env files containing real secrets to version control.
# =============================================================================

# --- Application ---
APP_NAME=BlueHub
APP_VERSION=0.1.0
APP_ENV=dev
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-secret-key-min-16-chars

# --- Server ---
HOST=0.0.0.0
PORT=8000
WORKERS=4
CORS_ORIGINS=["*"]

# --- Docker Services ---
# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=bluehub
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# MinIO (Object Storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Database (async with asyncpg) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bluehub
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false
DATABASE_MIGRATE_ON_START=true
DATABASE_TIMEOUT=30

# --- Redis (Application) ---
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10
REDIS_TIMEOUT=5
REDIS_SOCKET_KEEPALIVE=true
REDIS_RETRY_ON_TIMEOUT=true

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=false
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=["json"]
CELERY_MAX_RETRIES=3
CELERY_TASK_TRACK_STARTED=true
CELERY_TASK_TIME_LIMIT=3600
CELERY_BEAT_SCHEDULE_FILENAME=celerybeat-schedule

# --- JWT Authentication ---
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
# For development with HS256, leave these empty or set them.
# For production with RS256, provide PEM-encoded keys.
JWT_PUBLIC_KEY=
JWT_PRIVATE_KEY=
JWT_ISSUER=bluehub
JWT_AUDIENCE=bluehub-api

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=
LOG_INCLUDE_TRACEBACK=true

# --- File Storage ---
STORAGE_DIR=./storage
STORAGE_MAX_FILE_SIZE=104857600
STORAGE_ALLOWED_EXTENSIONS=["jpg","jpeg","png","gif","pdf","txt","zip","tar","gz"]

# --- MinIO / S3 Object Storage ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=bluehub
MINIO_SECURE=false
MINIO_REGION=us-east-1

# --- 2FA / TOTP ---
TOTP_ISSUER_NAME=BlueHub
TOTP_VALID_WINDOW=1

# --- Billing / Paymenter Integration ---
# Paymenter is the billing/payment management system running as a Docker service.
# It has its own MySQL database and web interface at PAYMENTER_APP_URL.
# The BlueHub API receives webhook events from Paymenter to sync users and payments.

# Paymenter Database (MySQL 8.0)
PAYMENTER_DB_ROOT_PASSWORD=paymenter_root
PAYMENTER_DB_NAME=paymenter
PAYMENTER_DB_USER=paymenter
PAYMENTER_DB_PASSWORD=paymenter_pass
PAYMENTER_DB_PORT=3307

# Paymenter Application
PAYMENTER_APP_NAME=BlueHub Billing
PAYMENTER_APP_ENV=local
PAYMENTER_APP_DEBUG=true
PAYMENTER_PORT=8080
PAYMENTER_APP_URL=http://localhost:8080
PAYMENTER_APP_KEY=

# Paymenter API (for BlueHub to query Paymenter)
PAYMENTER_BASE_URL=http://localhost:8080/api
PAYMENTER_API_KEY=
PAYMENTER_REQUEST_TIMEOUT=30

# Paymenter Webhook (sent TO BlueHub from Paymenter)
PAYMENTER_WEBHOOK_ENDPOINT=http://host.docker.internal:8000/api/v1/webhooks/paymenter
PAYMENTER_WEBHOOK_SECRET=paymenter_webhook_secret_change_me

# Paymenter Mail Settings
PAYMENTER_MAIL_MAILER=log
PAYMENTER_MAIL_HOST=
PAYMENTER_MAIL_PORT=587
PAYMENTER_MAIL_USERNAME=
PAYMENTER_MAIL_PASSWORD=
PAYMENTER_MAIL_ENCRYPTION=tls
PAYMENTER_MAIL_FROM_ADDRESS=noreply@bluehub.com

# Paymenter Payment Gateways (Stripe test mode)
PAYMENTER_STRIPE_KEY=
PAYMENTER_STRIPE_SECRET=
PAYMENTER_STRIPE_WEBHOOK_SECRET=

# --- Proxmox VE Integration ---
PROXMOX_HOST=
PROXMOX_PORT=8006
PROXMOX_USER=
PROXMOX_PASSWORD=
PROXMOX_VERIFY_SSL=false
PROXMOX_NODE=pve
PROXMOX_STORAGE=local-lvm
PROXMOX_BRIDGE=vmbr0

# --- MaxMind GeoIP ---
MAXMIND_LICENSE_KEY=
MAXMIND_DB_PATH=./data/geolite2.mmdb
MAXMIND_AUTO_UPDATE=true

# --- Prometheus / Monitoring ---
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_NAMESPACE=bluehub

# --- Rate Limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_GLOBAL=1000/minute

# --- Circuit Breaker ---
CIRCUIT_BREAKER_FAIL_MAX=5
CIRCUIT_BREAKER_RESET_TIMEOUT=60

# --- i18n ---
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=["en","fa","ar","tr","ru","de","fr","es"]
LOCALES_PATH=./config/locales

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_DROP_PENDING_UPDATES=true
TELEGRAM_ADMIN_IDS=[]
TELEGRAM_MAX_MESSAGE_LENGTH=4096

# --- Module Feature Flags ---
MODULE_VPN_ENABLED=true
MODULE_VPN_STOP_NEW_SALES=false
MODULE_VPN_TERMINATE_SERVICES=false

MODULE_VPS_ENABLED=true
MODULE_VPS_STOP_NEW_SALES=false
MODULE_VPS_TERMINATE_SERVICES=false

MODULE_SMARTDNS_ENABLED=true
MODULE_SMARTDNS_STOP_NEW_SALES=false
MODULE_SMARTDNS_TERMINATE_SERVICES=false

MODULE_STREAMING_ENABLED=true
MODULE_STREAMING_STOP_NEW_SALES=false
MODULE_STREAMING_TERMINATE_SERVICES=false

MODULE_GAME_ENABLED=true
MODULE_GAME_STOP_NEW_SALES=false
MODULE_GAME_TERMINATE_SERVICES=false

# --- Webhook Settings ---
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY=5
WEBHOOK_SIGNATURE_HEADER=X-Webhook-Signature
WEBHOOK_SIGNATURE_ALGORITHM=HMAC-SHA256

# --- Backup ---
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 3 * * *"
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=backups/